        "version": 2,
        "content": "<p><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Welcome to LogicMonitor</title></p><style>\n    :root {\n      --ink: #f7f9ff;\n      --muted: #b8c4da;\n      --quiet: #8090ac;\n      --line: rgba(255, 255, 255, .14);\n      --line-strong: rgba(255, 255, 255, .24);\n      --panel: rgba(13, 24, 45, .82);\n      --panel-soft: rgba(255, 255, 255, .06);\n      --panel-bright: #f7f9ff;\n      --blue: #246bfe;\n      --cyan: #48d7ff;\n      --lime: #d8ff37;\n      --mint: #5bf0b5;\n      --gold: #ffc857;\n      --rose: #ff6b6b;\n      --shadow: 0 20px 60px rgba(0, 0, 0, .28);\n      --radius: 8px;\n    }\n\n    html {\n      min-height: 100%;\n      background: #061021;\n    }\n\n    body {\n      min-height: 100%;\n      margin: 0;\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Arial, sans-serif;\n      color: var(--ink);\n      background:\n        radial-gradient(circle at 20% 0%, rgba(36, 107, 254, .30), transparent 28rem),\n        radial-gradient(circle at 90% 12%, rgba(72, 215, 255, .18), transparent 25rem),\n        linear-gradient(135deg, #071124 0%, #0b1930 46%, #101321 100%);\n    }\n\n    a {\n      color: inherit;\n    }\n\n    .lm-welcome,\n    .lm-welcome * {\n      box-sizing: border-box;\n    }\n\n    .lm-welcome {\n      min-height: 100vh;\n      padding: 22px;\n      overflow: hidden;\n      position: relative;\n      isolation: isolate;\n    }\n\n    .lm-welcome::before {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      z-index: -2;\n      opacity: .42;\n      background-image:\n        linear-gradient(rgba(255, 255, 255, .055) 1px, transparent 1px),\n        linear-gradient(90deg, rgba(255, 255, 255, .055) 1px, transparent 1px);\n      background-size: 42px 42px;\n      mask-image: linear-gradient(to bottom, #000 0%, rgba(0, 0, 0, .62) 42%, transparent 100%);\n    }\n\n    .lm-welcome::after {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      z-index: -1;\n      background:\n        linear-gradient(115deg, transparent 0 15%, rgba(216, 255, 55, .11) 15% 15.35%, transparent 15.35% 48%, rgba(72, 215, 255, .12) 48% 48.35%, transparent 48.35% 100%),\n        linear-gradient(25deg, transparent 0 67%, rgba(255, 255, 255, .10) 67% 67.2%, transparent 67.2% 100%);\n      opacity: .65;\n      pointer-events: none;\n    }\n\n    .lmw-shell {\n      width: min(1480px, 100%);\n      margin: 0 auto;\n      display: grid;\n      gap: 16px;\n    }\n\n    .lmw-topbar {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 16px;\n      padding: 2px 2px 0;\n    }\n\n    .lmw-brand {\n      display: inline-flex;\n      align-items: center;\n      gap: 10px;\n      min-width: 0;\n    }\n\n    .lmw-mark {\n      width: 32px;\n      height: 32px;\n      border-radius: 7px;\n      display: grid;\n      place-items: center;\n      background: linear-gradient(135deg, var(--blue), #1229ff);\n      box-shadow: 0 12px 32px rgba(36, 107, 254, .36);\n      flex: 0 0 auto;\n    }\n\n    .lmw-markGrid {\n      width: 17px;\n      height: 17px;\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 3px;\n    }\n\n    .lmw-markGrid span {\n      background: #fff;\n      border-radius: 2px;\n    }\n\n    .lmw-brandText {\n      min-width: 0;\n    }\n\n    .lmw-eyebrow {\n      margin: 0 0 2px;\n      color: var(--lime);\n      font-size: 11px;\n      font-weight: 800;\n      letter-spacing: .08em;\n      text-transform: uppercase;\n    }\n\n    .lmw-title {\n      margin: 0;\n      font-size: 22px;\n      line-height: 1.1;\n      font-weight: 760;\n      letter-spacing: 0;\n      white-space: nowrap;\n    }\n\n    .lmw-updated {\n      color: var(--muted);\n      font-size: 12px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, .06);\n      border-radius: 999px;\n      padding: 7px 10px;\n      white-space: nowrap;\n    }\n\n    .lmw-hero {\n      display: grid;\n      grid-template-columns: minmax(0, 1.12fr) minmax(360px, .88fr);\n      gap: 16px;\n      align-items: stretch;\n    }\n\n    .lmw-intro {\n      min-height: 360px;\n      border: 1px solid var(--line);\n      border-radius: var(--radius);\n      background:\n        linear-gradient(145deg, rgba(12, 26, 52, .94), rgba(11, 19, 34, .88)),\n        linear-gradient(90deg, rgba(72, 215, 255, .16), transparent);\n      box-shadow: var(--shadow);\n      padding: 30px;\n      display: grid;\n      align-content: space-between;\n      gap: 24px;\n      position: relative;\n      overflow: hidden;\n    }\n\n    .lmw-intro::after {\n      content: \"\";\n      position: absolute;\n      right: -80px;\n      bottom: -92px;\n      width: 420px;\n      height: 260px;\n      border: 1px solid rgba(216, 255, 55, .24);\n      transform: rotate(-18deg);\n      background:\n        linear-gradient(90deg, transparent 0 48%, rgba(72, 215, 255, .20) 48% 48.5%, transparent 48.5%),\n        linear-gradient(rgba(255, 255, 255, .06) 1px, transparent 1px);\n      background-size: 100% 100%, 28px 28px;\n      opacity: .54;\n    }\n\n    .lmw-copy {\n      max-width: 780px;\n      position: relative;\n      z-index: 1;\n    }\n\n    .lmw-copy h1 {\n      margin: 0;\n      max-width: 760px;\n      font-size: clamp(34px, 4.3vw, 64px);\n      line-height: .98;\n      font-weight: 820;\n      letter-spacing: 0;\n    }\n\n    .lmw-copy p {\n      margin: 18px 0 0;\n      max-width: 700px;\n      color: var(--muted);\n      font-size: 17px;\n      line-height: 1.55;\n    }\n\n    .lmw-actions {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 10px;\n      position: relative;\n      z-index: 1;\n    }\n\n    .lmw-button {\n      min-height: 42px;\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      gap: 8px;\n      padding: 10px 14px;\n      border-radius: 7px;\n      border: 1px solid var(--line-strong);\n      text-decoration: none;\n      color: var(--ink);\n      background: rgba(255, 255, 255, .08);\n      font-size: 13px;\n      font-weight: 760;\n      line-height: 1.2;\n    }\n\n    .lmw-buttonPrimary {\n      color: #061021;\n      background: var(--lime);\n      border-color: rgba(216, 255, 55, .85);\n      box-shadow: 0 14px 30px rgba(216, 255, 55, .18);\n    }\n\n    .lmw-button:hover,\n    .lmw-resource:hover,\n    .lmw-card:hover {\n      transform: translateY(-1px);\n      border-color: rgba(216, 255, 55, .50);\n    }\n\n    .lmw-path {\n      border: 1px solid var(--line);\n      border-radius: var(--radius);\n      background: rgba(247, 249, 255, .96);\n      color: #111827;\n      box-shadow: var(--shadow);\n      padding: 20px;\n      display: grid;\n      gap: 14px;\n    }\n\n    .lmw-panelLabel {\n      margin: 0;\n      color: #246bfe;\n      font-size: 11px;\n      font-weight: 850;\n      letter-spacing: .08em;\n      text-transform: uppercase;\n    }\n\n    .lmw-path h2,\n    .lmw-section h2 {\n      margin: 0;\n      font-size: 18px;\n      line-height: 1.25;\n      letter-spacing: 0;\n    }\n\n    .lmw-steps {\n      display: grid;\n      gap: 10px;\n      margin: 0;\n      padding: 0;\n      list-style: none;\n    }\n\n    .lmw-step {\n      display: grid;\n      grid-template-columns: 34px minmax(0, 1fr);\n      gap: 10px;\n      align-items: start;\n      padding: 11px;\n      border-radius: var(--radius);\n      background: #fff;\n      border: 1px solid rgba(17, 24, 39, .10);\n    }\n\n    .lmw-num {\n      width: 26px;\n      height: 26px;\n      display: inline-grid;\n      place-items: center;\n      border-radius: 7px;\n      color: #061021;\n      background: #e8eeff;\n      border: 1px solid #cfd9ff;\n      font-size: 12px;\n      font-weight: 850;\n    }\n\n    .lmw-step:nth-child(2) .lmw-num {\n      background: #e8fbff;\n      border-color: #b5effc;\n    }\n\n    .lmw-step:nth-child(3) .lmw-num {\n      background: #f1ffd0;\n      border-color: #d9f98e;\n    }\n\n    .lmw-step:nth-child(4) .lmw-num {\n      background: #fff4da;\n      border-color: #ffe1a6;\n    }\n\n    .lmw-step h3 {\n      margin: 0 0 3px;\n      font-size: 14px;\n      line-height: 1.2;\n      letter-spacing: 0;\n    }\n\n    .lmw-step p {\n      margin: 0;\n      color: #526070;\n      font-size: 12px;\n      line-height: 1.4;\n    }\n\n    .lmw-stepLinks {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 6px;\n      margin-top: 8px;\n    }\n\n    .lmw-stepLinks a {\n      display: inline-flex;\n      align-items: center;\n      min-height: 24px;\n      padding: 4px 8px;\n      border-radius: 999px;\n      border: 1px solid rgba(36, 107, 254, .20);\n      background: rgba(36, 107, 254, .07);\n      color: #1849c6;\n      text-decoration: none;\n      font-size: 11px;\n      font-weight: 780;\n      line-height: 1.2;\n    }\n\n    .lmw-stepLinks a:hover {\n      border-color: rgba(36, 107, 254, .42);\n      background: rgba(36, 107, 254, .12);\n    }\n\n    .lmw-section {\n      border: 1px solid var(--line);\n      border-radius: var(--radius);\n      background: rgba(8, 18, 36, .72);\n      box-shadow: var(--shadow);\n      padding: 18px;\n    }\n\n    .lmw-section--essentials {\n      padding-bottom: 10px;\n    }\n\n    .lmw-section--essentials .lmw-card {\n      min-height: 130px !important;\n      padding-bottom: 42px;\n    }\n\n    .lmw-sectionHead {\n      display: flex;\n      align-items: end;\n      justify-content: space-between;\n      gap: 16px;\n      margin-bottom: 14px;\n    }\n\n    .lmw-sectionHead p {\n      margin: 4px 0 0;\n      color: var(--muted);\n      font-size: 13px;\n      line-height: 1.45;\n    }\n\n    .lmw-sectionTag {\n      color: var(--quiet);\n      font-size: 12px;\n      white-space: nowrap;\n    }\n\n    .lmw-cardGrid {\n      display: grid;\n      grid-template-columns: repeat(4, minmax(0, 1fr));\n      gap: 12px;\n      align-items: start;\n    }\n\n    .lmw-card {\n      display: block;\n      position: relative;\n      align-self: start;\n      height: auto !important;\n      min-height: 0 !important;\n      padding: 15px 15px 42px;\n      border: 1px solid var(--line);\n      border-radius: var(--radius);\n      background: linear-gradient(180deg, rgba(255, 255, 255, .085), rgba(255, 255, 255, .045));\n      text-decoration: none;\n      transition: transform .16s ease, border-color .16s ease, background .16s ease;\n    }\n\n    .lmw-cardTop {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 8px;\n      margin-bottom: 12px;\n    }\n\n    .lmw-icon {\n      width: 32px;\n      height: 32px;\n      border-radius: 7px;\n      display: grid;\n      place-items: center;\n      color: #061021;\n      font-size: 15px;\n      font-weight: 900;\n      background: var(--cyan);\n      flex: 0 0 auto;\n    }\n\n    .lmw-card:nth-child(2) .lmw-icon,\n    .lmw-resource:nth-child(2) .lmw-icon {\n      background: var(--lime);\n    }\n\n    .lmw-card:nth-child(3) .lmw-icon,\n    .lmw-resource:nth-child(3) .lmw-icon {\n      background: var(--gold);\n    }\n\n    .lmw-card:nth-child(4) .lmw-icon,\n    .lmw-resource:nth-child(4) .lmw-icon {\n      background: var(--mint);\n    }\n\n    .lmw-pill {\n      color: var(--muted);\n      font-size: 11px;\n      font-weight: 760;\n      border: 1px solid var(--line);\n      border-radius: 999px;\n      padding: 4px 8px;\n      background: rgba(255, 255, 255, .055);\n      white-space: nowrap;\n    }\n\n    .lmw-card h3,\n    .lmw-resource h3 {\n      margin: 0;\n      font-size: 16px;\n      line-height: 1.2;\n      letter-spacing: 0;\n    }\n\n    .lmw-cardTop h3 {\n      flex: 1 1 auto;\n      min-width: 0;\n    }\n\n    .lmw-card p,\n    .lmw-resource p {\n      margin: 0;\n      color: var(--muted);\n      font-size: 13px;\n      line-height: 1.45;\n    }\n\n    .lmw-linkText {\n      margin-top: 4px;\n      color: #fff;\n      font-size: 13px;\n      font-weight: 800;\n      text-align: right;\n      align-self: flex-end;\n    }\n\n    .lmw-card > .lmw-linkText {\n      position: absolute;\n      right: 15px;\n      bottom: 14px;\n      margin-top: 0;\n      display: block;\n    }\n\n    .lmw-resourceGrid {\n      display: grid;\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n      gap: 12px;\n      align-items: start;\n    }\n\n    .lmw-resource {\n      display: block;\n      align-self: start;\n      height: auto !important;\n      min-height: 0 !important;\n      padding: 15px;\n      border: 1px solid var(--line);\n      border-radius: var(--radius);\n      background: rgba(255, 255, 255, .955);\n      color: #101828;\n      text-decoration: none;\n      transition: transform .16s ease, border-color .16s ease;\n    }\n\n    .lmw-resourceText {\n      display: block;\n      width: 100%;\n      min-width: 100%;\n      max-width: 100%;\n      text-align: left;\n      white-space: normal;\n      word-break: normal;\n      overflow-wrap: normal;\n    }\n\n    .lmw-resourceTitle {\n      display: flex;\n      align-items: center;\n      gap: 10px;\n      margin-bottom: 8px;\n    }\n\n    .lmw-resource p {\n      color: #566275;\n      white-space: normal;\n      word-break: normal;\n      overflow-wrap: normal;\n    }\n\n    .lmw-resource .lmw-linkText {\n      color: #1849c6;\n      margin-top: 4px;\n      display: block;\n    }\n\n    .lmw-footer {\n      display: flex;\n      align-items: center;\n      justify-content: flex-end;\n      gap: 16px;\n      color: var(--quiet);\n      font-size: 12px;\n      padding: 0 2px 2px;\n    }\n\n    .lmw-footer a {\n      color: var(--muted);\n      text-decoration: none;\n      font-weight: 700;\n    }\n\n    @media (max-width: 1180px) {\n      .lmw-hero {\n        grid-template-columns: 1fr;\n      }\n\n      .lmw-cardGrid {\n        grid-template-columns: repeat(2, minmax(0, 1fr));\n      }\n    }\n\n    @media (max-width: 860px) {\n      .lm-welcome {\n        padding: 14px;\n      }\n\n      .lmw-topbar,\n      .lmw-sectionHead,\n      .lmw-footer {\n        align-items: flex-start;\n        flex-direction: column;\n      }\n\n      .lmw-updated,\n      .lmw-sectionTag,\n      .lmw-title {\n        white-space: normal;\n      }\n\n      .lmw-intro {\n        min-height: 0;\n        padding: 22px;\n      }\n\n      .lmw-copy h1 {\n        font-size: 36px;\n      }\n\n      .lmw-resourceGrid {\n        grid-template-columns: 1fr;\n      }\n    }\n\n    @media (max-width: 620px) {\n      .lmw-cardGrid {\n        grid-template-columns: 1fr;\n      }\n\n      .lmw-path {\n        padding: 15px;\n      }\n\n      .lmw-button {\n        width: 100%;\n      }\n    }\n  </style><main class=\"lm-welcome\" aria-label=\"Welcome to LogicMonitor\"><div class=\"lmw-shell\"><header class=\"lmw-topbar\"><div class=\"lmw-brand\"><div class=\"lmw-mark\" aria-hidden=\"true\"><div class=\"lmw-markGrid\"><span></span><span></span><span></span><span></span></div></div><div class=\"lmw-brandText\"><p class=\"lmw-eyebrow\">New account starting point</p><p class=\"lmw-title\">Welcome to LogicMonitor</p></div></div><div class=\"lmw-updated\">Curated for onboarding, operations, and support</div></header><section class=\"lmw-hero\"><div class=\"lmw-intro\"><div class=\"lmw-copy\"><h1>Build a stronger foundation for hybrid observability.</h1><p>Start here for the resources your team will use most while getting started with LogicMonitor. Follow the setup guides, training paths, and support links to connect your environment, tune alerts, and build operational confidence.</p></div><div class=\"lmw-actions\" aria-label=\"Primary resources\"><a class=\"lmw-button lmw-buttonPrimary\" href=\"https://academy.logicmonitor.com/getting-started-badge\" target=\"_blank\" rel=\"noopener\">Start the academy path &rarr;</a> <a class=\"lmw-button\" href=\"https://www.logicmonitor.com/support\" target=\"_blank\" rel=\"noopener\">Open support center</a> <a class=\"lmw-button\" href=\"https://status.logicmonitor.com/\" target=\"_blank\" rel=\"noopener\">Check system status</a></div></div><aside class=\"lmw-path\" aria-label=\"Recommended first steps\"><p class=\"lmw-panelLabel\">Recommended first steps</p><h2>Start with the essentials.</h2><ol class=\"lmw-steps\"><li class=\"lmw-step\"><span class=\"lmw-num\">1</span><div><h3>Plan the rollout</h3><p>Define owners, priority resource groups, escalation paths, and what success looks like for the first 30 days.</p><div class=\"lmw-stepLinks\"><a href=\"https://www.logicmonitor.com/support/getting-started/implementation-readiness/logicmonitor-implementation-readiness-recommendations-for-enterprise-customers\" target=\"_blank\" rel=\"noopener\">Readiness guide</a> <a href=\"https://www.logicmonitor.com/support/getting-started/implementation-readiness/top-dependencies-for-logicmonitor-enterprise-implementation\" target=\"_blank\" rel=\"noopener\">Top dependencies</a></div></div></li><li class=\"lmw-step\"><span class=\"lmw-num\">2</span><div><h3>Connect the signals</h3><p>Deploy collectors, add cloud or SaaS accounts, and confirm resources are landing in the right groups.</p><div class=\"lmw-stepLinks\"><a href=\"https://www.logicmonitor.com/support/adding-collector\" target=\"_blank\" rel=\"noopener\">Add collectors</a> <a href=\"https://www.logicmonitor.com/support/introduction-to-cloud-monitoring\" target=\"_blank\" rel=\"noopener\">Cloud monitoring</a> <a href=\"https://www.logicmonitor.com/support/netscans\" target=\"_blank\" rel=\"noopener\">NetScans</a></div></div></li><li class=\"lmw-step\"><span class=\"lmw-num\">3</span><div><h3>Tune for action</h3><p>Review alert thresholds, recipients, and routing so notifications are useful from the beginning.</p><div class=\"lmw-stepLinks\"><a href=\"https://www.logicmonitor.com/support/alert-threshold-overview\" target=\"_blank\" rel=\"noopener\">Alert thresholds</a> <a href=\"https://www.logicmonitor.com/support/escalation-chains\" target=\"_blank\" rel=\"noopener\">Escalation chains</a> <a href=\"https://www.logicmonitor.com/support/alert-rules\" target=\"_blank\" rel=\"noopener\">Alert rules</a></div></div></li><li class=\"lmw-step\"><span class=\"lmw-num\">4</span><div><h3>Operationalize</h3><p>Use dashboards, reports, and release notes to keep teams aligned as coverage expands.</p><div class=\"lmw-stepLinks\"><a href=\"https://www.logicmonitor.com/support/dashboard-management\" target=\"_blank\" rel=\"noopener\">Dashboard management</a> <a href=\"https://www.logicmonitor.com/support/adding-resource-groups\" target=\"_blank\" rel=\"noopener\">Resource groups</a></div></div></li></ol></aside></section><section class=\"lmw-section lmw-section--essentials\" aria-labelledby=\"lmw-essentials-title\"><div class=\"lmw-sectionHead\"><div><h2 id=\"lmw-essentials-title\">Essentials for day one</h2><p>Quick access to documentation, training, release notes, and security information.</p></div><div class=\"lmw-sectionTag\">Docs, training, health, trust</div></div><div class=\"lmw-cardGrid\"><a class=\"lmw-card\" href=\"https://www.logicmonitor.com/support\" target=\"_blank\" rel=\"noopener\"><div class=\"lmw-cardTop\"><span class=\"lmw-icon\">D</span><h3>Support Center</h3><span class=\"lmw-pill\">Docs</span></div><p>Product documentation, platform concepts, configuration guides, and operational references.</p><span class=\"lmw-linkText\">Open docs &rarr;</span>&nbsp;</a> <a class=\"lmw-card\" href=\"https://academy.logicmonitor.com/\" target=\"_blank\" rel=\"noopener\"><div class=\"lmw-cardTop\"><span class=\"lmw-icon\">A</span><h3>LogicMonitor Academy</h3><span class=\"lmw-pill\">Training</span></div><p>Role-based learning paths for administrators, operators, and teams getting started.</p><span class=\"lmw-linkText\">Start learning &rarr;</span>&nbsp;</a> <a class=\"lmw-card\" href=\"https://www.logicmonitor.com/release-notes\" target=\"_blank\" rel=\"noopener\"><div class=\"lmw-cardTop\"><span class=\"lmw-icon\">R</span><h3>Release Notes</h3><span class=\"lmw-pill\">Updates</span></div><p>Track platform updates, new capabilities, and changes that may affect your rollout.</p><span class=\"lmw-linkText\">View updates &rarr;</span>&nbsp;</a> <a class=\"lmw-card\" href=\"https://trust.logicmonitor.com/\" target=\"_blank\" rel=\"noopener\"><div class=\"lmw-cardTop\"><span class=\"lmw-icon\">T</span><h3>Trust Center</h3><span class=\"lmw-pill\">Security</span></div><p>Security, compliance, privacy, and reliability information for governance reviews.</p><span class=\"lmw-linkText\">Review trust center &rarr;</span>&nbsp;</a></div></section><section class=\"lmw-section\" aria-labelledby=\"lmw-operate-title\"><div class=\"lmw-sectionHead\"><div><h2 id=\"lmw-operate-title\">Operate with confidence</h2><p>Continue building your LogicMonitor practice with planning guidance, community insights, and support options.</p></div><div class=\"lmw-sectionTag\">Implementation, community, support</div></div><div class=\"lmw-resourceGrid\"><a class=\"lmw-resource\" href=\"https://www.logicmonitor.com/support/getting-started/implementation-readiness/logicmonitor-implementation-readiness-recommendations-for-enterprise-customers\" target=\"_blank\" rel=\"noopener\"><div class=\"lmw-resourceText\"><div class=\"lmw-resourceTitle\"><span class=\"lmw-icon\">1</span><h3>Implementation readiness</h3></div><p>Readiness recommendations for planning deployment and ownership across teams.</p><span class=\"lmw-linkText\">Read guide &rarr;</span></div></a> <a class=\"lmw-resource\" href=\"https://community.logicmonitor.com/\" target=\"_blank\" rel=\"noopener\"><div class=\"lmw-resourceText\"><div class=\"lmw-resourceTitle\"><span class=\"lmw-icon\">2</span><h3>LogicMonitor Community</h3></div><p>Peer discussion, practical examples, and operational patterns from other users.</p><span class=\"lmw-linkText\">Visit community &rarr;</span></div></a> <a class=\"lmw-resource\" href=\"https://www.logicmonitor.com/support/about-logicmonitor/customer-support/logicmonitor-technical-support-packages\" target=\"_blank\" rel=\"noopener\"><div class=\"lmw-resourceText\"><div class=\"lmw-resourceTitle\"><span class=\"lmw-icon\">3</span><h3>Technical support</h3></div><p>Understand support options and where to go when the rollout needs expert help.</p><span class=\"lmw-linkText\">Get help &rarr;</span></div></a></div></section><footer class=\"lmw-footer\"><a href=\"https://www.logicmonitor.com/\" target=\"_blank\" rel=\"noopener\">logicmonitor.com</a></footer></div></main>"
      }
    }
  ],
